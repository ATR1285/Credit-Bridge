# CreditBridge Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to git!

# ==========================================
# REQUIRED - Flask & Database
# ==========================================

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(24))")
SECRET_KEY=your-secret-key-here

# Database connection (PostgreSQL recommended)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ==========================================
# REQUIRED - Authentication
# ==========================================

# Google OAuth (for customer portal login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================
# REQUIRED - AI Services
# ==========================================

# Gemini API Key (for document analysis)
GEMINI_API_KEY=your-gemini-api-key

# ==========================================
# OPTIONAL - Background Tasks
# ==========================================

# Redis URL for Celery (default: memory://)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ==========================================
# OPTIONAL - Application Settings
# ==========================================

# Flask environment (development/production)
FLASK_ENV=development
FLASK_DEBUG=false

# File upload settings
UPLOAD_FOLDER=uploads
REPORTS_FOLDER=reports
MAX_CONTENT_LENGTH=10485760

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ==========================================
# OPTIONAL - ML Operations
# ==========================================

# MLflow tracking URI
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db

# Model registry path
MODEL_REGISTRY_PATH=models/
